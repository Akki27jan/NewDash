# -----------------------------------------------------------------------------
# STUDENT DASHBOARD - HOMELAB ENVIRONMENT VARIABLES
# -----------------------------------------------------------------------------
# Copy this file to '.env' and fill in the values below.
# By default, these values are configured for local Docker Compose hosting.
# -----------------------------------------------------------------------------

# --- BACKEND SETTINGS ---

# Database Connection String
# Since the db runs in a docker container named 'studentdash_postgres',
# we connect to it using the service name 'db'.
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/student_dash

# JWT Authentication
# Change this to a secure random string for production
JWT_SECRET=super_secret_homelab_key_change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200  # 30 days

# Notification Settings (Optional)
# Set these if you want email notifications to work
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com


# --- FRONTEND SETTINGS ---

# Public URL of your backend API
# If you access the dashboard from a different PC, change 'localhost' to 
# the IP address of the machine hosting the Docker containers (e.g., 192.168.1.100).
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- DATABASE SETTINGS (For the Postgres Container) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=student_dash
